{
  "name": "builder-sandbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:test": "cross-env PLAYWRIGHT_TEST=true next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:install": "playwright install --with-deps chromium",
    "tests": "npm run test:install && playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug"
  },
  "dependencies": {
    "@builder.io/dev-tools": "^1.28.18",
    "@builder.io/sdk-react": "^5.2.0",
    "isomorphic-dompurify": "^3.0.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "react-scan": "^0.5.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
